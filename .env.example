# ─── Database (required) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── App (required) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Security ──────────────────────────────────────────────────────────────────
# JWT session signing — generate with: openssl rand -hex 32
AUTH_SECRET=your_64_char_hex_here
# AES-256 encryption of stored API keys — generate with: openssl rand -hex 16
API_KEY_ENCRYPTION_SECRET=your_32_char_hex_here

# ─── LLM Provider fallbacks (optional — set via Settings UI instead) ───────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
